# Server
PORT=5000
MONGODB_URI=mongodb://localhost:27017/mimi-crunch

# Shiprocket fulfillment (shipping labels) — apiv2.shiprocket.in
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_API_SECRET=
SHIPROCKET_PICKUP_LOCATION=Primary
SHIPROCKET_PICKUP_PINCODE=

# Shiprocket Checkout (iframe checkout) — checkout-api.shiprocket.com
SHIPROCKET_API_KEY=
SHIPROCKET_SECRET_KEY=
# If Shiprocket rejects HMAC / key format, try one of these (see their doc):
# SHIPROCKET_CHECKOUT_HMAC_ENCODING=hex
# SHIPROCKET_CHECKOUT_X_API_KEY_RAW=1
# Optional full X-Api-Key header value (overrides Bearer mode):
# SHIPROCKET_CHECKOUT_X_API_KEY_HEADER=
# Override token URL path if their doc differs:
# SHIPROCKET_CHECKOUT_ACCESS_TOKEN_PATH=/api/v1/access-token/checkout
# Optional override; default https://checkout-api.shiprocket.com
# SHIPROCKET_CHECKOUT_API_BASE=
# Optional: custom order details API (default in lib/shiprocket/fetchOrder.js)
# SHIPROCKET_ORDER_DETAILS_URL=

# Site URL for access-token redirect_url default
SITE_URL=https://www.mimicrunch.com

# Return raw Shiprocket errors to client JSON (never enable in public prod unless needed):
# SHIPROCKET_DEBUG=1

# Fast2SMS OTP (https://www.fast2sms.com)
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# OTP expiry in milliseconds (default: 600000 = 10 minutes)
OTP_EXPIRY_MS=600000

# CORS (comma-separated)
# CORS_ORIGIN=https://www.example.com
